NODE_ENV=development
JWT_SECRET=replace-with-at-least-32-random-characters
DB_DATABASE=dev.sqlite
# Production (Supabase Session Pooler, port 5432). Never commit the real value.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# Keep the initial free-tier connection pool deliberately small.
DB_POOL_MAX=5
# Private object storage. Keep the service-role key on the server only.
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_SECRET_KEY=replace-with-server-secret-key
SUPABASE_STORAGE_BUCKET=family-media
HOST=0.0.0.0
PORT=3001
# Comma-separated browser origins. Native Android clients do not require CORS.
CORS_ORIGINS=
